rules_version = '2';


service cloud.firestore {
  match /databases/{database}/documents {
    match /startups/{startupUid} {
      // Public directory — only the founder can create/edit their own.
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == startupUid;
    }

    match /users/{uid}/notifications/{notifId} {
      // Written by whichever party triggers them, not just the owner.
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
    }

    match /opportunities/{oppId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.startupId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.startupId == request.auth.uid;
    }

    match /applications/{appId} {
      allow read: if request.auth != null
        && (resource.data.studentUid == request.auth.uid
            || resource.data.startupId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.studentUid == request.auth.uid;
      // Students withdraw; founders move the pipeline stage forward.
      allow update: if request.auth != null
        && (resource.data.studentUid == request.auth.uid
            || resource.data.startupId == request.auth.uid);
    }

    match /chats/{chatId} {
      function isParty(data) {
        return request.auth != null
          && (data.studentUid == request.auth.uid
              || data.startupUid == request.auth.uid);
      }

      allow read, update: if isParty(resource.data);
      allow create: if isParty(request.resource.data);

      match /messages/{messageId} {
        allow read: if isParty(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isParty(get(/databases/$(database)/documents/chats/$(chatId)).data)
          && request.resource.data.senderUid == request.auth.uid;
      }
    }
  }
}
